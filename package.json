{
  "name": "lunke-bot",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.lunke.bot",
    "productName": "LunkeBot",
    "win": {
      "target": [
        "portable"
      ]
    },
    "files": [
      "main.js",
      "views/**/*"
    ]
  },
  "dependencies": {
    "express": "^4.19.2",
    "mineflayer": "^4.22.0",
    "socks": "^2.8.3"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2"
  }
}
